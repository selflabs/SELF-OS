# SELF OS Personal Intelligence — optional model provider configuration
#
# Copy this file to `.env` and fill in values locally. Never commit `.env`.
# Community Edition example agents are deterministic and do NOT read this file.
# Use these variables when you add your own agent integrations (see docs/LOCAL_MODELS.md).

# --- Cloud model providers (BYO keys) ---

# OpenAI — https://platform.openai.com/docs/api-reference
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic (Claude) — https://docs.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (Gemini) — https://ai.google.dev
GEMINI_API_KEY=your-gemini-key-here

# OpenRouter — https://openrouter.ai/docs
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Resonatia — https://resonatia.io/docs
RESONATIA_API_KEY=your-resonatia-bearer-token-here
RESONATIA_API_BASE=https://api.resonatia.io

# --- Optional defaults for custom agents ---

# Model id passed to your provider client (vendor-specific string)
DEFAULT_MODEL_ID=

# Set to 1 to allow outbound HTTPS from agents you implement (not used by stock CE agents)
AGENT_NETWORK_ENABLED=0
